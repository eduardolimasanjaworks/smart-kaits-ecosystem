# Front (Vite) — copie para .env.local se necessário
# Origens do portal que podem enviar postMessage com o JWT (separadas por vírgula).
# Ex.: https://sistema.kaits.com.br,https://app.kaits.com.br,https://smartkaits.techfala.com.br
# Em dev local do portal: http://127.0.0.1:5055
VITE_EMBED_ALLOWED_ORIGINS=

# URL base da API REST do Kaits (página hospedeira), para usar com kaitsPortalFetch() e o Bearer enviado via postMessage.
# Ex.: https://app.kaits.com.br/api
# VITE_KAITS_PORTAL_API_URL=

# Se "true": sem iframe e sem token → não mostra login slug/senha; só aviso para usar o portal KAITS.
# Útil em produção para bloquear link direto ao domínio público.
# VITE_REQUIRE_EMBED=false
