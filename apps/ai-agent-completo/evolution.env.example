# Variáveis para docker compose da Evolution (não é lido pelo FastAPI).
# Copie para evolution.env e defina EVOLUTION_AUTH_KEY.
#
# Uso: docker compose --env-file evolution.env -f docker-compose.infra.yml up -d
#
EVOLUTION_AUTH_KEY=troque-esta-chave-evolution
EVOLUTION_SERVER_URL=http://127.0.0.1:8090
EVOLUTION_HOST_PORT=8091
#
# Se sendText falhar com @lid (exists:false), na stack raiz do ecosystem use no .env:
# EVOLUTION_DOCKER_IMAGE=evoapicloud/evolution-api:latest
#
# CONFIG_SESSION_PHONE_VERSION=2.3000.xxxxx.xxxxx
