# URL base da API Smart Kaits (sem barra final)
KAITS_API_URL=http://127.0.0.1:8000

# Mesmo valor que EMBED_TRUST_SECRET no backend Smart Kaits
EMBED_TRUST_SECRET=coloque-o-mesmo-segredo-de-32-plus-caracteres

# URL base do front Vue/Vite do Smart Kaits (onde abre o chat no iframe)
KAITS_FRONTEND_URL=http://127.0.0.1:5173

# Duas escolas reais criadas na API (slugs diferentes → dois tenants, duas instâncias Evolution sk_<uuid>)
SCHOOL_A_SLUG=escola-demo-a
SCHOOL_B_SLUG=escola-demo-b

# Porta desta app “portal falso”
MOCK_KAITS_PORT=5055

# Bearer fictício enviado ao iframe via postMessage (SMART_KAITS_KAITS_HOST_BEARER) para testar API Kaits
# MOCK_KAITS_HOST_BEARER=mock-kaits-host-bearer-token
