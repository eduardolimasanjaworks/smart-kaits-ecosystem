# Variáveis de Ambiente — Smart Kaits Backend
# Copie para .env e preencha com seus valores reais.
# NUNCA comite o .env no repositório.

# ── Banco de Dados ─────────────────────────────────────────
# Formato: postgresql+asyncpg://usuario:senha@host:porta/banco
DATABASE_URL=postgresql+asyncpg://kaits:senha123@localhost:5432/kaits_dev

# ── Segurança ──────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-isso-por-uma-chave-aleatoria-segura

# Algoritmo JWT (não altere sem ler ADR-003)
JWT_ALGORITHM=HS256

# Expiração do token em minutos (padrão: 7 dias)
JWT_EXPIRE_MINUTES=10080

# ── Ambiente ───────────────────────────────────────────────
ENVIRONMENT=development   # development | production

# ── CORS ───────────────────────────────────────────────────
# Origens permitidas, separadas por vírgula
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Upload de Arquivos ─────────────────────────────────────
# Diretório local para salvar arquivos (relativo ao backend/)
UPLOAD_DIR=uploads

# Tamanho máximo por arquivo em MB
MAX_UPLOAD_MB=10
