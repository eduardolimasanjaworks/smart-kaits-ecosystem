# Variáveis opcionais para o docker compose na raiz desta pasta.
# Copie: cp .env.example .env  e preencha. O Compose injeta no backend.
#
# CHATWOOT_IDENTITY_TOKEN deve ser idêntico ao "Identity validation" do inbox
# Website no painel do Chatwoot, junto com CHATWOOT_WEBSITE_TOKEN.

# Evolution + Smart Kaits backend (mesmo segredo nos dois lados).
EVOLUTION_AUTH_KEY=troque-esta-chave-evolution
# URL pública da Evolution (SERVER_URL dentro do container). Ex.: https://evolucao.seudominio.com ou http://IP:8091
EVOLUTION_SERVER_URL=http://127.0.0.1:8091
EVOLUTION_HOST_PORT=8091
# Opcional: versão do WhatsApp Web que o Baileys emula (Evolution). Ajuda quando o /connect só retorna {"count":0}.
# Confira o formato atual em https://web.whatsapp.com/check-update?version=0&platform=web e cole aqui.
# Exemplo (troque se o WA atualizar): CONFIG_SESSION_PHONE_VERSION=2.3000.1038507070.261501
CONFIG_SESSION_PHONE_VERSION=

# Webhook: base pública da API Smart Kaits (sem /api/v1).
EVOLUTION_WEBHOOK_PUBLIC_BASE=https://aiagent.sanjaworks.com

OPENAI_API_KEY=

BACKEND_SECRET_KEY=
CHATWOOT_WIDGET_URL=https://chat.techfala.com.br
CHATWOOT_WEBSITE_TOKEN=
CHATWOOT_IDENTITY_TOKEN=
